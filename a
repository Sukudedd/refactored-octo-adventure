<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>sukuded</title>
    <style>
        body { margin: 0; padding: 0; height: 100vh; overflow: hidden; background: #000; }
        
        /* Arka plan GIF ayarları */
        #bg-gif { 
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
            object-fit: cover; z-index: 0; transition: opacity 1.5s ease-in-out; 
        }
        
        /* Giriş ekranı - Sadece başlangıçta görünür */
        #start-screen { 
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.7); color: #A0B9D9; 
            display: flex; justify-content: center; align-items: center; 
            z-index: 10; cursor: pointer; font-size: 18px; 
            letter-spacing: 4px; font-family: 'Courier New', monospace;
            text-shadow: 0 0 10px rgba(160, 185, 217, 0.5);
        }
    </style>
</head>
<body>

    <div id="start-screen" onclick="startSite()">[ SİSTEME GİRİŞ İÇİN TIKLA ]</div>
    
    <img id="bg-gif" src="rei1.gif" alt="background">

    <audio id="bg-music" loop><source src="music.mp3" type="audio/mpeg"></audio>

    <script>
        const bg = document.getElementById("bg-gif");
        const gifs = ['rei1.gif', 'rei2.gif', 'rei3.gif', 'rei4.gif', 'rei5.gif'];
        let gifIndex = 0;

        // 8 saniyede bir GIF değiştirme döngüsü
        setInterval(() => {
            gifIndex = (gifIndex + 1) % gifs.length;
            bg.style.opacity = 0;
            setTimeout(() => { 
                bg.src = gifs[gifIndex]; 
                bg.style.opacity = 1; 
            }, 750);
        }, 8000);

        function startSite() {
            // Tam ekran modu
            if (document.documentElement.requestFullscreen) document.documentElement.requestFullscreen();
            
            // Başlangıç ekranını kaldır
            document.getElementById('start-screen').style.display = 'none';
            
            // Müziği başlat
            document.getElementById('bg-music').play();
        }
    </script>
</body>
</html>
